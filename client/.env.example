# ============================================================
# DeFi WebApp — Client Environment Configuration
# Sao chép file này thành .env và điền giá trị thực tế vào
# ============================================================

# === Backend API ===
VITE_API_BASE_URL=http://localhost:8080

# === Blockchain Network ===
VITE_CHAIN_ID=11155111
VITE_NETWORK_NAME=Sepolia
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/KZNIIMe0fczLJf0VLuLjF

# ============================================================
# Contract Addresses — Điền vào sau khi deploy lên Sepolia
# Thứ tự deploy: Token → DefiVault → Staking → SimpleAMM → WalletStaking
# ============================================================

# SKT Token (ERC-20 underlying asset)
VITE_TOKEN_ADDRESS=

# DefiVault (ERC-4626 Tokenized Vault) — phát hành dvSKT (share token)
VITE_DEFI_VAULT_ADDRESS=

# StakingStrategyController (Strategy-based, kết nối với DefiVault)
VITE_STAKING_ADDRESS=

# SimpleAMM (ETH↔SKT swap pool)
VITE_SIMPLE_AMM_ADDRESS=

# WalletStaking (Legacy — giữ lại để so sánh học thuật Fixed APR vs Dynamic Yield)
VITE_WALLET_STAKING_ADDRESS=

# ============================================================
# UI / UX Configuration
# ============================================================

# Slippage mặc định (basis points: 100 = 1%)
VITE_DEFAULT_SLIPPAGE_BPS=100

# Slippage tối đa cho phép (basis points: 3000 = 30%)
VITE_MAX_SLIPPAGE_BPS=3000

# Khoảng thời gian poll on-chain data (milliseconds)
VITE_POLL_INTERVAL_MS=30000

# Etherscan block explorer base URL
VITE_ETHERSCAN_BASE_URL=https://sepolia.etherscan.io
